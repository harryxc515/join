# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (to receive startup messages)
DEVELOPER_CHAT_ID=your_chat_id_here

# MongoDB connection string (from MongoDB Atlas)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/join-hider?retryWrites=true&w=majority

# Port (Render sets this automatically — do NOT set manually on Render)
# PORT=3000
